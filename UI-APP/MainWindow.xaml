<Window x:Class="Edj20Tester.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Edj20Tester"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#1E1E1E" Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="EDJ20 TESTING SYSTEM"
               Foreground="Lime"
               FontSize="28"
               FontWeight="Bold"
               Margin="0,0,0,20"/>

        <!-- Top Controls -->
        <StackPanel Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,0,0,20">

            <Button Name="btnStart"
                Click="btnStart_Click"
                Content="START TEST"
                Width="140"
                Height="40"
                Background="Black"
                Foreground="Lime"
                BorderBrush="Lime"
                FontWeight="Bold"/>

        </StackPanel>

        <!-- Log Area -->
        <TextBox Grid.Row="2"
             Name="txtLog"
             Background="Black"
             Foreground="Lime"
             FontFamily="Consolas"
             FontSize="14"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             TextWrapping="Wrap"/>

        <!-- Status -->
        <Border Grid.Row="3"
            Background="#222"
            Padding="10"
            Margin="0,20,0,0">

            <TextBlock Text="STATUS: READY"
                   Foreground="Cyan"
                   FontSize="18"
                   FontWeight="Bold"/>
        </Border>

    </Grid>
</Window>
